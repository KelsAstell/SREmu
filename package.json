{
  "name": "starrail-warp-simulator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 25173",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "npm run build-only && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy": "npm run build-only && wrangler deploy"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^7.0.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.79.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
